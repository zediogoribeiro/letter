{
  "format_on_save": "on",
  "languages": {
    "JavaScript": {
      "formatter": { "language_server": { "name": "biome" } }
    },
    "JSX": {
      "formatter": { "language_server": { "name": "biome" } }
    },
    "TypeScript": {
      "formatter": { "language_server": { "name": "biome" } }
    },
    "TSX": {
      "formatter": { "language_server": { "name": "biome" } }
    },
    "JSON": {
      "formatter": { "language_server": { "name": "biome" } }
    },
    "CSS": {
      "formatter": { "language_server": { "name": "biome" } }
    }
  },
  "lsp": {
    "vscode-css-language-server": {
      "settings": {
        "css": { "lint": { "unknownAtRules": "ignore" } },
        "scss": { "lint": { "unknownAtRules": "ignore" } },
        "less": { "lint": { "unknownAtRules": "ignore" } }
      }
    }
  }
}
