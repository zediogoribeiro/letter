# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------

# Base URL of the application
BETTER_AUTH_URL=http://localhost:3000

# Secret used by Better Auth
BETTER_AUTH_SECRET=

# -----------------------------------------------------------------------------
# Database (Neon)
# -----------------------------------------------------------------------------

DATABASE_URL=

# -----------------------------------------------------------------------------
# Admin
# -----------------------------------------------------------------------------

# Email domain(s) with admin access (include @)
# Example: @company.com
ADMIN_EMAIL_DOMAIN=

# Developer email with admin access
DEVELOPER_EMAIL=

# -----------------------------------------------------------------------------
# Google OAuth
# -----------------------------------------------------------------------------

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Cloudflare R2 (Image Storage)
# -----------------------------------------------------------------------------

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
